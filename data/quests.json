    "dialogs": {
      "accept": [
        {
          "speaker": "曹彰",
          "text": "是曹樱叫你来的吗？"
        },
        {
          "speaker": "你",
          "text": "是的，这里有封你的家信。"
        },
        {
          "speaker": "曹彰",
          "text": "那就谢过将军了。"
        }
      ],
      "complete": [
        {
          "speaker": "曹彰",
          "text": "我这就回一封，还请将军带回去一趟。"
        },
        {
          "speaker": "你",
          "text": "好，小事一桩！"
        }
      ]
    },
    "next_hint": "前往「厢房」与『曹樱』对话",
    "next_quest": "main_05",
    "grant_item": {
      "item_id": "quest_jiashu",
      "item_name": "家书",
      "count": 1
    }
  },
